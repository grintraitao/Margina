---
// Sao chép liên kết + chia sẻ hệ thống. Xử lý ở script trung tâm (BaseLayout).
---
<div class="post-actions">
  <button class="btn" type="button" data-copy>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
      <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
    </svg>
    <span data-copy-label>Sao chép liên kết</span>
  </button>
  <button class="btn" type="button" data-share hidden>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"></path>
    </svg>
    Chia sẻ
  </button>
</div>
