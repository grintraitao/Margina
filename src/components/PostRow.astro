---
import type { CollectionEntry } from "astro:content";
import { formatDate, isoDate } from "../utils/date";
import { estimateReadingTime } from "../utils/reading";
import Rating from "./Rating.astro";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const d = post.data;
const reading = d.readingTime ?? estimateReadingTime(post.body);
---

<li>
  <a class="post-row" href={`/posts/${post.id}`} style={`--accent:${d.accent}`}>
    <span class="row-title">{d.title}</span>
    {d.subtitle && <span class="row-sub">{d.subtitle}</span>}
    <span class="row-meta">
      {d.author && <span class="who">{d.author}</span>}
      {d.author && <span class="dot">·</span>}
      <span>{reading}</span>
      <span class="dot">·</span>
      <time datetime={isoDate(d.date)}>{formatDate(d.date)}</time>
      {d.rating != null && <span class="dot">·</span>}
      {d.rating != null && <Rating value={d.rating} />}
      {
        d.tags.length > 0 && (
          <span class="row-tags">
            {d.tags.map((t) => (
              <span class="chip">{t}</span>
            ))}
          </span>
        )
      }
    </span>
  </a>
</li>
