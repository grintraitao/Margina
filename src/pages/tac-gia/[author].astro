---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostRow from "../../components/PostRow.astro";
import { tagSlug } from "../../utils/tags";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const map = new Map<string, { author: string; posts: CollectionEntry<"posts">[] }>();
  for (const p of posts) {
    const a = p.data.author;
    if (!a) continue;
    const slug = tagSlug(a);
    if (!map.has(slug)) map.set(slug, { author: a, posts: [] });
    map.get(slug)!.posts.push(p);
  }
  return Array.from(map.entries()).map(([slug, entry]) => ({
    params: { author: slug },
    props: {
      author: entry.author,
      posts: entry.posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

interface Props {
  author: string;
  posts: CollectionEntry<"posts">[];
}
const { author, posts } = Astro.props;
---

<BaseLayout title={`Tác giả: ${author}`} description={`Các bản dịch từ bài viết của ${author}.`}>
  <div class="home">
    <div class="home-intro">
      <p class="back-link"><a href="/">← Tất cả bài</a></p>
      <h1>{author}</h1>
      <p>{posts.length} bài dịch từ tác giả này</p>
    </div>
    <ul class="post-rows">
      {posts.map((post) => <PostRow post={post} />)}
    </ul>
  </div>
</BaseLayout>
